EXPO_PUBLIC_API_BASE_URL=https://nemnidhi.cloud/api
EXPO_PUBLIC_SOCKET_URL=https://nemnidhi.cloud
EXPO_PUBLIC_SOCKET_PATH=/socket.io

# Optional local API mode for Expo dev
# EXPO_PUBLIC_USE_LOCAL_API=true
# EXPO_PUBLIC_LOCAL_API_PORT=4000

# Optional TURN relay for reliable mobile-data calls (recommended in production)
# EXPO_PUBLIC_TURN_URL=turn:your-turn-host:3478
# EXPO_PUBLIC_TURN_URLS=turn:your-turn-host:3478,turns:your-turn-host:5349
# EXPO_PUBLIC_TURN_USERNAME=your-username
# EXPO_PUBLIC_TURN_CREDENTIAL=your-password
